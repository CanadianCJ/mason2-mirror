$Base = (Split-Path (Split-Path $PSScriptRoot -Parent) -Parent)
$Rep  = Join-Path $Base 'reports'
$Arc  = Join-Path $Rep  'archive'
New-Item -ItemType Directory -Force -Path $Arc | Out-Null
$limit = 5MB
Get-ChildItem $Rep -File -Filter *.jsonl -ErrorAction SilentlyContinue | ForEach-Object {
  if ($_.Length -ge $limit) {
    $stamp = (Get-Date).ToString('yyyyMMdd_HHmmss')
    $rot   = Join-Path $Rep ("..jsonl")
    Move-Item $_.FullName $rot -Force
    $zip = Join-Path $Arc ("..zip")
    Compress-Archive -Path $rot -DestinationPath $zip -Force
    Remove-Item $rot -Force
    Out-MasonJsonl -Kind 'rotate' -Event 'rotated' -Level 'INFO' -Data @{ file=$_.Name; zip=(Split-Path $zip -Leaf); size=$_.Length }
  }
}
