{
  "version": 2,
  "policy_name": "internal_scheduler_foundation",
  "task_classes": [
    "health",
    "validation",
    "mirror",
    "queue",
    "housekeeping",
    "reports"
  ],
  "risk_classes": [
    "low",
    "guarded",
    "review_only"
  ],
  "default_run_modes": {
    "bootstrap": "windows_task_scheduler",
    "steady_state": "mason_internal_scheduler",
    "fallback": "windows_task_scheduler"
  },
  "history": {
    "max_entries_per_task": 25,
    "max_run_records": 60
  },
  "bootstrap_task": {
    "task_name": "Mason2-InternalScheduler-10m",
    "task_path": "\\Mason2\\",
    "cadence_minutes": 10,
    "hidden": true,
    "run_level": "LeastPrivilege",
    "logon_type": "InteractiveToken",
    "script_rel_path": "tools\\ops\\Run_Internal_Scheduler_Once.ps1"
  },
  "foundation_tasks": [
    {
      "task_id": "athena_status_snapshot",
      "category": "health",
      "cadence_minutes": 10,
      "enabled": true,
      "risk_class": "low",
      "script_rel_path": "tools\\Athena_Status_Snapshot.ps1",
      "host_task_name": "Mason2-AthenaStatus-10m",
      "audit_artifact": "reports\\athena_widget_status.json",
      "schedule_owner": "internal_primary",
      "host_action_on_migration": "disable_host_keep_fallback_record",
      "execution_arguments": []
    },
    {
      "task_id": "onyx_health_check",
      "category": "health",
      "cadence_minutes": 10,
      "enabled": true,
      "risk_class": "low",
      "script_rel_path": "tools\\Onyx_Health_Check.ps1",
      "host_task_name": "Mason2-OnyxHealth-10m",
      "audit_artifact": "reports\\onyx_stack_health.json",
      "schedule_owner": "internal_primary",
      "host_action_on_migration": "disable_host_keep_fallback_record",
      "execution_arguments": []
    },
    {
      "task_id": "system_validation_refresh",
      "category": "validation",
      "cadence_minutes": 60,
      "enabled": true,
      "risk_class": "guarded",
      "script_rel_path": "tools\\ops\\Validate_Whole_System.ps1",
      "host_task_name": "Mason2-TaskGovernor-1h",
      "audit_artifact": "reports\\system_validation_last.json",
      "schedule_owner": "internal_primary",
      "host_action_on_migration": "keep_disabled_host_as_fallback_record",
      "execution_arguments": []
    },
    {
      "task_id": "mirror_refresh",
      "category": "mirror",
      "cadence_minutes": 60,
      "enabled": true,
      "risk_class": "guarded",
      "script_rel_path": "tools\\sync\\Mason_Mirror_Update.ps1",
      "host_task_name": "Mason2 Mirror Update",
      "audit_artifact": "reports\\mirror_update_last.json",
      "schedule_owner": "host_primary",
      "host_action_on_migration": "keep_host_as_fallback",
      "execution_arguments": [
        "-Reason",
        "internal-scheduler"
      ]
    },
    {
      "task_id": "whole_folder_verification",
      "category": "validation",
      "cadence_minutes": 360,
      "enabled": false,
      "risk_class": "guarded",
      "script_rel_path": "tools\\ops\\Run_Whole_Folder_Verification.ps1",
      "host_task_name": "",
      "audit_artifact": "reports\\whole_folder_verification_last.json",
      "schedule_owner": "manual_only",
      "host_action_on_migration": "definition_only",
      "execution_arguments": []
    },
    {
      "task_id": "morning_report",
      "category": "reports",
      "cadence_minutes": 1440,
      "enabled": true,
      "risk_class": "low",
      "script_rel_path": "tools\\Mason_Morning_Report.ps1",
      "host_task_name": "Mason_Morning_Report_9AM",
      "audit_artifact": "reports\\daily_report_last.json",
      "schedule_owner": "host_primary",
      "host_action_on_migration": "keep_host_but_hide_console",
      "execution_arguments": [
        "-SuppressOpen"
      ]
    }
  ]
}
